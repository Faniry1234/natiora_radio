# Use SQLite locally by default. To force MySQL, set DB_DRIVER=mysql and fill DB_* values.
DB_DRIVER=sqlite
# Relative path from project root to sqlite file (will be created if missing)
DB_PATH=DATA/database.sqlite

# If you prefer MySQL instead, uncomment and set values below:
#DB_DRIVER=mysql
#DB_HOST=127.0.0.1
#DB_PORT=3306
#DB_NAME=natiora_radio
#DB_USER=db_user
#DB_PASS=your_db_password_here

# Base URL (optional)
BASE_URL=http://localhost:8000

APP_ENV=production
APP_DEBUG=false
DB_CONNECTION=mysql
